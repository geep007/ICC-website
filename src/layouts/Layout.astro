---
import '@fontsource/poppins/400.css';
import '@fontsource/poppins/500.css';
import '@fontsource/poppins/600.css';
import '@fontsource/poppins/700.css';
import '@fontsource/manrope/500.css';
import '@fontsource/poor-story/400.css';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Independent Creators Co. — be the greater fool',
  description = 'A medium-agnostic agency, a multidisciplinary mothership, a creative ecosystem. Your brand’s GTM bestie.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/icons/co-icon.png" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <script>
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const targets = document.querySelectorAll('[data-reveal], [data-reveal-mask]');
      if (prefersReduced) {
        targets.forEach((el) => el.classList.add('is-visible'));
      } else {
        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.15, rootMargin: '0px 0px -5% 0px' },
        );
        targets.forEach((el) => observer.observe(el));
      }
    </script>
  </body>
</html>
