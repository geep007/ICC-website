---
// Full-bleed media section ("Website hands glitch" in Figma).
// The video is stored at public/videos/website-hands-glitch.mp4
---

<section class="gif-section">
  <video src="/videos/website-hands-glitch.mp4" autoplay muted loop playsinline></video>
</section>

<style>
  .gif-section {
    /* Match the Figma frame ratio (1920x1080) instead of forcing viewport
       height, so the section never reads as an empty gap. */
    aspect-ratio: 16 / 9;
    max-height: 100svh;
    width: 100%;
    overflow: hidden;
  }

  .gif-section img,
  .gif-section video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
