---
import type { SiteContent } from '../content/defaults';

interface Props {
  footer: SiteContent['footer'];
}
const { footer } = Astro.props;
---

<footer class="footer">
  <div class="footer__talk" data-reveal>
    <p class="footer__talk-heading">{footer.heading}</p>
    <div class="footer__methods">
      {footer.methods.map((method) => (
        <a class="footer__method" href={method.href}>
          <img src={method.icon} alt="" width="40" height="40" />
          <span>{method.label}</span>
        </a>
      ))}
    </div>
  </div>

  <div class="footer__brand">
    <p class="footer__credit" data-reveal>{footer.creditLine}</p>
    <p class="footer__wordmark" data-reveal style="--reveal-delay: 150ms">
      <span>independent</span>
      <span>creators.co</span>
    </p>
    <div class="footer__logo" data-reveal-mask style="--reveal-delay: 150ms">
      <div class="footer__logo-crop">
        <img src="/images/footer-logo.png" alt="independent creators co." loading="lazy" />
      </div>
    </div>
    <nav class="footer__nav" aria-label="Footer">
      {footer.navLinks.map((link) => (
        <a href={`#${link.toLowerCase().replace(/[^a-z]+/g, '-')}`}>{link}</a>
      ))}
    </nav>
  </div>
</footer>

<style>
  .footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(60px, 7vw, 140px);
    padding-block: clamp(60px, 5.2vw, 100px) 0;
    overflow: hidden;
  }

  .footer__talk {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .footer__talk-heading {
    font-size: var(--fs-body-lg);
    font-weight: 700;
    text-transform: lowercase;
    color: var(--c-yellow);
  }

  .footer__methods {
    display: flex;
    gap: clamp(20px, 3vw, 60px);
  }

  .footer__method {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    font-size: var(--fs-body-lg);
    font-weight: 500;
    text-transform: lowercase;
    transition: transform 250ms var(--ease-out);
  }

  .footer__method img {
    width: clamp(28px, 2vw, 40px);
    height: auto;
  }

  @media (hover: hover) {
    .footer__method:hover {
      transform: translateY(-4px);
      color: var(--c-yellow);
    }
  }

  .footer__brand {
    position: relative;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .footer__credit {
    font-size: var(--fs-body-lg);
    font-weight: 500;
    text-transform: lowercase;
    margin-bottom: -0.5em;
    z-index: 1;
  }

  /* Replicates the Figma crop of the square source logo (1920/558 window). */
  .footer__logo-crop {
    position: relative;
    width: 100vw;
    aspect-ratio: 1920 / 558;
    overflow: hidden;
  }

  .footer__logo-crop img {
    position: absolute;
    width: 124.38%;
    max-width: none;
    height: auto;
    left: -12.44%;
    top: -162.53%;
  }

  .footer__nav {
    position: absolute;
    left: clamp(20px, 2vw, 40px);
    bottom: clamp(16px, 2vw, 90px);
    display: flex;
    flex-direction: column;
    font-size: var(--fs-body-lg);
    font-weight: 500;
    text-transform: lowercase;
    line-height: 1.5;
    z-index: 10;
  }

  .footer__nav a {
    transition: color 200ms ease;
  }

  @media (hover: hover) {
    .footer__nav a:hover {
      color: var(--c-yellow);
    }
  }

  /* Desktop swaps the cropped image wordmark for the Figma text version? No, mobile does. */
  .footer__wordmark {
    display: none;
  }

  @media (max-width: 768px) {
    .footer {
      gap: 60px;
      padding-block: 50px 0;
    }

    .footer__methods {
      flex-wrap: wrap;
      justify-content: center;
    }

    .footer__logo {
      display: none;
    }

    .footer__wordmark {
      display: flex;
      flex-direction: column;
      font-size: 42px;
      font-weight: 600;
      line-height: 1;
      text-transform: lowercase;
      text-align: center;
      color: var(--c-yellow);
      margin-top: 20px;
    }

    .footer__credit {
      margin-bottom: 0;
      font-size: 14px;
    }

    .footer__nav {
      position: static;
      flex-direction: row;
      flex-wrap: wrap;
      gap: 12px;
      justify-content: center;
      padding: 40px var(--pad-x) 50px;
      font-size: 12px;
    }
  }
</style>
