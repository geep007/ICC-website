---
import type { SiteContent } from '../content/defaults';

interface Props {
  hero: SiteContent['hero'];
}
const { hero } = Astro.props;
---

<section class="hero" id="top">
  <div class="hero__inner">
    <h1 class="hero__title">
      <span class="hero__line hero__line--1" data-reveal-mask style="--reveal-delay: 350ms">
        <span>{hero.titleLine1}</span>
      </span>
      <span class="hero__line hero__line--2" data-reveal-mask style="--reveal-delay: 500ms">
        <span>{hero.titleLine2}</span>
      </span>
    </h1>
    <div class="hero__aside">
      <p class="hero__tagline" data-reveal style="--reveal-delay: 800ms">{hero.tagline}</p>
      <a class="pill-btn" href={hero.ctaHref} data-reveal style="--reveal-delay: 950ms">{hero.ctaText}</a>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(120px, 12vw, 200px) var(--pad-x) 50px;
  }

  .hero__inner {
    width: min(1484px, 100%);
    position: relative;
  }

  .hero__title {
    font-size: var(--fs-display);
    font-weight: 600;
    text-transform: lowercase;
    line-height: 0.95;
    display: flex;
    flex-direction: column;
  }

  .hero__line--2 {
    align-self: center;
    padding-left: clamp(0px, 8vw, 160px);
  }

  .hero__aside {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 36px;
    margin-top: clamp(32px, 4vw, 70px);
    margin-left: auto;
    max-width: 436px;
  }

  .hero__tagline {
    font-size: var(--fs-body-lg);
    font-weight: 500;
    text-transform: lowercase;
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 90svh;
      align-items: flex-start;
      padding-top: 130px;
    }

    .hero__line--2 {
      align-self: flex-start;
      padding-left: 0;
    }

    .hero__aside {
      margin-left: 0;
      margin-top: 40px;
    }
  }
</style>
